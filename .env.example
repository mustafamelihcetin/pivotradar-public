# PIVOTRADAR Infrastructure Configuration
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ── Veritabanı ────────────────────────────────────────────────────────────────
POSTGRES_USER=pivot_user
POSTGRES_PASSWORD=pivot_pass         # Production'da güçlü bir şifre kullanın
POSTGRES_DB=pivotradar

# ── Uygulama ──────────────────────────────────────────────────────────────────
HOST_PORT=80
SECRET_KEY=generate_a_long_random_string_here  # python -c "import secrets; print(secrets.token_hex(32))"
ENVIRONMENT=production               # production | development | test

# ── Hata Takibi (Sentry) ──────────────────────────────────────────────────────
# Adım: sentry.io → ücretsiz hesap → Create Project → Python → DSN'i kopyala
# Ücretsiz plan: 5.000 event/ay yeterli. Production'da ZORUNLUDUR.
SENTRY_DSN=

# ── Fatura Uyarısı (Hetzner) ──────────────────────────────────────────────────
# Sunucu IP bloklandığında Cloudflare 523 hatası verir.
# Adım: Hetzner Robot → Billing → Email Alerts → aylık limit + email gir
# (Kod değil, manuel panel ayarıdır — bu satır hatırlatma içindir)
# HETZNER_BILLING_ALERT=ornek@email.com

# ── Dış Servisler (Opsiyonel) ─────────────────────────────────────────────────
CF_WORKER_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Cloudflare Turnstile (Bot Koruması) ───────────────────────────────────────
# Adım: dash.cloudflare.com → Turnstile → Add Site → Site Key + Secret Key
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ENABLED=False

# ── Frontend Build (Vite) ─────────────────────────────────────────────────────
# Docker build sırasında JS bundle'a işlenir — buraya SECRET koymayın.
VITE_GOOGLE_CLIENT_ID=
VITE_API_BASE=
VITE_TURNSTILE_SITE_KEY=
